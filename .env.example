# PLC Monitor System Environment Variables
# Copy this file to .env and customize as needed

# PLC Connection Settings
PLC_HOST=172.15.14.150
PLC_RACK=0
PLC_SLOT=1
PLC_CONNECTION_TIMEOUT=5000
PLC_RETRY_INTERVAL=3000
PLC_MAX_RETRY_ATTEMPTS=10
PLC_RECONNECT_BACKOFF_ENABLED=1

# Data Collection Settings
DATA_SAMPLING_INTERVAL=100
DATA_HISTORY_DAYS=30
DATA_CACHE_MAX_SIZE=10000
DATA_CACHE_EXPIRE_SECONDS=300

# Analysis Settings
ANALYSIS_WINDOW_SIZE=60
ANALYSIS_THRESHOLD=0.8
ANALYSIS_PREDICTION_INTERVAL=5000
ANALYSIS_ENABLED=1

# Server Settings
SERVER_PORT=3000
SERVER_HOST=0.0.0.0
SERVER_DEBUG=0
SERVER_WORKERS=1

# Logging Settings
LOGGING_LEVEL=info
LOGGING_FILE=./logs/app.log
LOGGING_MAX_FILE_SIZE=10485760
LOGGING_BACKUP_COUNT=5

# SocketIO Settings
SOCKETIO_ASYNC_MODE=threading
SOCKETIO_CORS_ALLOWED_ORIGINS=*
SOCKETIO_TRANSPORTS=polling

# Database Settings
DATABASE_PATH=./database.db
DATABASE_TIMEOUT=30
DATABASE_CACHE_SIZE=10000

# Connection Pool Settings
CONNECTION_POOL_MAX_WORKERS=10
CONNECTION_POOL_HEALTH_CHECK_INTERVAL=10

# Health Check Settings
HEALTH_CHECK_ENABLED=1
HEALTH_CHECK_INTERVAL=30